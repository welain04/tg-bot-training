BOT_TOKEN=
ADMIN_CHAT_ID=
GOOGLE_SHEETS_ID=
GOOGLE_CREDENTIALS_PATH=credentials/google_service_account.json
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
TIMEZONE=Europe/Moscow

# Тексты клиники (можно изменить)
# Важно: сохраняйте .env в кодировке UTF-8
CLINIC_NAME=Стоматологическая клиника
CLINIC_ABOUT=Мы оказываем полный спектр стоматологических услуг: консультации, лечение, профессиональную гигиену и хирургию.
CLINIC_ADDRESS=уточняйте у администратора
CLINIC_PHONE=уточняйте у администратора
CLINIC_HOURS=Пн–Сб, по предварительной записи

# Поведение бота
FSM_TIMEOUT_MINUTES=30
CALLBACK_THROTTLE_SECONDS=0.4
LOG_LEVEL=INFO

# Production: Redis для сохранения сессий между перезапусками
# REDIS_URL=redis://redis:6379/0
