BOT_TOKEN=
ADMIN_CHAT_ID=
GOOGLE_SHEETS_ID=
GOOGLE_CREDENTIALS_PATH=credentials/google_service_account.json
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}
TIMEZONE=Europe/Moscow

# Тексты клиники — в config/clinic.toml (UTF-8, деплоятся вместе с кодом из GitHub)

# AI-помощник (Groq, бесплатный tier). Промпт — config/ai_prompt.toml
# Ключ: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TEMPERATURE=0.3
GROQ_MAX_TOKENS=300

# Поведение бота
FSM_TIMEOUT_MINUTES=30
CALLBACK_THROTTLE_SECONDS=0.4
LOG_LEVEL=INFO

# Production: Redis для сохранения сессий между перезапусками
# REDIS_URL=redis://redis:6379/0
